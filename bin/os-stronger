#!/usr/bin/env node
// os-stronger CLI entry point
const { init, enhancements } = require('../src/init');

const args = process.argv.slice(2);
const cmd = args[0];

if (cmd === 'init') {
  const restore = args.includes('--restore');
  let enhArg = null;
  const enhIdx = args.indexOf('--enhancements');
  if (enhIdx !== -1 && args[enhIdx + 1]) {
    enhArg = args[enhIdx + 1].split(',').map(s => s.trim()).filter(Boolean);
  }
  const dir = process.cwd();
  init(dir, { restore, enhancements: enhArg })
    .then(ok => process.exit(ok ? 0 : 1))
    .catch(e => {
      console.error('  \x1b[31m✗\x1b[0m ' + (e && e.message || e));
      process.exit(1);
    });
} else {
  console.log('os-stronger — OpenSpec enhancement layer\n');
  console.log('Usage:');
  console.log('  os-stronger init                                    # 交互式选择增强');
  console.log('  os-stronger init --enhancements review,skill-align  # 静默指定');
  console.log('  os-stronger init --restore                          # 撤销所有增强');
  const enhEntries = Object.entries(enhancements);
  if (enhEntries.length > 0) {
    console.log('\nAvailable enhancements:');
    for (const [id, enh] of enhEntries) {
      // label 自带 id 前缀(如 "review — ..."),去掉避免重复
      const desc = enh.label ? enh.label.replace(/^.+?—\s*/, '') : '';
      console.log('  ' + id.padEnd(14) + desc);
    }
  }
  process.exit(0);
}
