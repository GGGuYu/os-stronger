#!/usr/bin/env node
// os-stronger CLI entry point
const { execSync } = require('child_process');
const path = require('path');
const { init, enhancements } = require('../src/init');
const { handleGoal } = require('../goal/scripts/cli');
const pkg = require('../package.json');

const GITHUB_REPO = 'GGGuYu/os-stronger';

const args = process.argv.slice(2);
const cmd = args[0];

if (cmd === '--version' || cmd === '-v') {
  console.log('os-stronger v' + pkg.version);
  process.exit(0);
}

if (cmd === '--update') {
  console.log('os-stronger — 更新中...\n');
  try {
    // 两个关键点:
    // 1. 用 HTTPS 拉 GitHub,避免 npm 默认走 SSH 时因无 SSH key 失败(publickey denied)
    // 2. 用当前 node 同目录的 npm(process.execPath 的兄弟),而非 PATH 里随便哪个 npm——
    //    多 node 环境下 PATH 的 npm 可能属于另一个 node,装到错误的全局目录,导致自己永远更新不到
    const nodeBin = process.execPath;
    const npmBin = path.join(path.dirname(nodeBin), 'npm');
    execSync(`"${npmBin}" install -g https://github.com/${GITHUB_REPO}.git`, { stdio: 'inherit' });
    console.log('\n  \x1b[32m✓\x1b[0m os-stronger 已更新到最新版。');
    console.log('  如需更新项目中的增强,在项目目录跑 \x1b[36mos-stronger init\x1b[0m 重新注入。');
  } catch (e) {
    console.error('  \x1b[31m✗\x1b[0x 更新失败: ' + (e.message || e));
    process.exit(1);
  }
  process.exit(0);
}

if (cmd === '--uninstall') {
  console.log('os-stronger — 卸载中...\n');
  console.log('  \x1b[33m!\x1b[0m 卸载前，请先在各项目目录跑 \x1b[36mos-stronger init --restore\x1b[0m 撤销增强。');
  console.log('  \x1b[33m!\x1b[0m 如果还没 restore 就卸载了 CLI，需重新安装后跑 restore，再卸载。');
  console.log('');
  try {
    execSync(`npm uninstall -g os-stronger`, { stdio: 'inherit' });
    console.log('\n  \x1b[32m✓\x1b[0m os-stronger 全局 CLI 已卸载。');
  } catch (e) {
    console.error('  \x1b[31m✗\x1b[0m 卸载失败: ' + (e.message || e));
    process.exit(1);
  }
  process.exit(0);
}

if (cmd === 'goal') {
  const code = handleGoal(args.slice(1));
  process.exit(code || 0);
}

if (cmd === 'init') {
  const restore = args.includes('--restore');
  let enhArg = null;
  const enhIdx = args.indexOf('--enhancements');
  if (enhIdx !== -1 && args[enhIdx + 1]) {
    enhArg = args[enhIdx + 1].split(',').map(s => s.trim()).filter(Boolean);
  }
  const dir = process.cwd();
  init(dir, { restore, enhancements: enhArg })
    .then(ok => process.exit(ok ? 0 : 1))
    .catch(e => {
      console.error('  \x1b[31m✗\x1b[0m ' + (e && e.message || e));
      process.exit(1);
    });
} else {
  console.log('os-stronger — OpenSpec enhancement layer v' + pkg.version + '\n');
  console.log('Usage:');
  console.log('  os-stronger init                                    # 交互式选择增强');
  console.log('  os-stronger init --enhancements review,skill-align,goal  # 静默指定');
  console.log('  os-stronger init --restore                          # 撤销项目中的增强');
  console.log('');
  console.log('Package management:');
  console.log('  os-stronger --update                                # 更新全局 CLI (从 GitHub 拉)');
  console.log('  os-stronger --uninstall                             # 卸载全局 CLI');
  console.log('  os-stronger --version                               # 查看版本');
  console.log('  os-stronger goal <subcommand>                        # 长程目标编排');
  console.log('    goal create / change / instructions / test-failed / resume / status / list');
  console.log('');
  const enhEntries = Object.entries(enhancements);
  if (enhEntries.length > 0) {
    console.log('Available enhancements:');
    for (const [id, enh] of enhEntries) {
      const desc = enh.label ? enh.label.replace(/^.+?—\s*/, '') : '';
      console.log('  ' + id.padEnd(14) + desc);
    }
  }
  process.exit(0);
}
